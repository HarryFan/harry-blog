---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const publicDir = fileURLToPath(new URL('../../../public/', import.meta.url));

const hashTitle = (input: string) => {
	let hash = 5381;
	for (let i = 0; i < input.length; i += 1) {
		hash = ((hash << 5) + hash) ^ input.charCodeAt(i);
	}
	return hash >>> 0;
};

const resolveHeroSrc = (input?: string) => {
	if (!input) return undefined;
	if (!input.startsWith('/')) return input;
	const absolutePath = path.join(publicDir, input.slice(1));
	if (!fs.existsSync(absolutePath)) return undefined;
	return `${import.meta.env.BASE_URL}${input.slice(1)}`;
};

const coverSvgDataUri = (title: string) => {
	const hash = hashTitle(title);
	const hueA = hash % 360;
	const hueB = (hueA + 60 + ((hash >>> 8) % 120)) % 360;
	const hueC = (hueB + 40 + ((hash >>> 16) % 80)) % 360;
	const a = `hsl(${hueA} 85% 55%)`;
	const b = `hsl(${hueB} 90% 50%)`;
	const c = `hsl(${hueC} 85% 60%)`;
	const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="1440" height="720" viewBox="0 0 1440 720"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="${a}"/><stop offset="0.55" stop-color="${b}"/><stop offset="1" stop-color="${c}"/></linearGradient><linearGradient id="s" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="rgba(0,0,0,0.55)"/><stop offset="0.65" stop-color="rgba(0,0,0,0)"/></linearGradient><pattern id="p" width="18" height="18" patternUnits="userSpaceOnUse" patternTransform="rotate(28)"><rect width="18" height="18" fill="none"/><path d="M0 9H18" stroke="rgba(255,255,255,0.13)" stroke-width="2"/></pattern></defs><rect width="1440" height="720" fill="url(#g)"/><rect width="1440" height="720" fill="url(#p)" opacity="0.75"/><rect width="1440" height="720" fill="url(#s)"/><g opacity="0.9" fill="rgba(255,255,255,0.85)" font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial" font-weight="700" letter-spacing="0.28em" font-size="22"><text x="72" y="92">HARRY BLOG</text></g><g opacity="0.7" fill="rgba(255,255,255,0.75)" font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, Courier New, monospace" font-size="16"><text x="72" y="138">HASH:${hash.toString(16).padStart(8, '0')}</text></g><circle cx="1320" cy="96" r="10" fill="rgba(255,255,255,0.85)"/><circle cx="1352" cy="96" r="10" fill="rgba(255,255,255,0.55)"/><circle cx="1384" cy="96" r="10" fill="rgba(255,255,255,0.25)"/></svg>`;
	return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.intro-section {
				margin-bottom: clamp(2rem, 4vw, 3.5rem);
			}
			.intro-shell {
				display: grid;
				grid-template-columns: minmax(0, 1fr) clamp(180px, 22vw, 240px);
				grid-template-areas: 'copy portrait';
				gap: clamp(1.25rem, 3vw, 2rem);
				padding: clamp(1.25rem, 3vw, 2rem);
				border-top: 1px solid rgb(var(--gray-light));
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.intro-copy {
				grid-area: copy;
				min-width: 0;
			}
			.intro-kicker {
				margin: 0 0 0.8rem;
				font-size: 0.95rem;
				font-weight: 700;
				color: rgb(var(--gray));
			}
			.intro-section h2 {
				margin: 0 0 0.85rem;
				font-size: clamp(1.65rem, 2.2vw, 2.05rem);
				letter-spacing: -0.02em;
			}
			.intro-lede {
				margin: 0 0 0.9rem;
				max-width: 62ch;
				color: rgb(var(--gray-dark));
			}
			.intro-note {
				margin: 0 0 1.25rem;
				max-width: 62ch;
				color: rgb(var(--gray-dark));
			}
			.intro-contacts {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem 1.1rem;
				list-style: none;
				margin: 1.25rem 0 0;
				padding: 1.1rem 0 0;
				border-top: 1px solid rgba(var(--gray), 22%);
			}
			.intro-contacts li {
				display: inline-flex;
				align-items: baseline;
				gap: 0.5rem;
				min-width: 0;
			}
			.intro-contacts__label {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.intro-contacts__value {
				font-weight: 700;
				color: rgb(var(--black));
				overflow-wrap: anywhere;
			}
			.intro-contacts a {
				color: rgb(var(--black));
				text-decoration: none;
				border-bottom: 1px solid rgba(var(--gray), 35%);
			}
			.intro-contacts a:hover {
				border-bottom-color: rgba(var(--gray), 65%);
			}
			.intro-portrait {
				grid-area: portrait;
				margin: 0;
				justify-self: end;
				align-self: start;
				display: grid;
				justify-items: center;
				gap: 0.65rem;
				text-align: center;
			}
			.intro-portrait img {
				width: clamp(160px, 20vw, 240px);
				aspect-ratio: 1 / 1;
				object-fit: cover;
				border-radius: 16px;
				border: 1px solid rgba(var(--gray), 24%);
			}
			.intro-portrait figcaption {
				margin: 0;
				font-size: 0.95rem;
				font-style: italic;
				color: rgb(var(--gray));
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
				.intro-shell {
					grid-template-columns: 1fr;
					grid-template-areas:
						'portrait'
						'copy';
					padding: 1.1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-section">
				<div class="intro-shell">
					<div class="intro-copy">
						<p class="intro-kicker">Harry / Tech</p>
						<h2>我是 Harry，與你分享前端路上會用到的技巧與觀念</h2>
						<p class="intro-lede">
							每個人看事情的觀點與生命歷程都不一樣，一切以你思考過後得到的想法為主。
						</p>
						<p class="intro-note">
							之後若有前端聚會想邀請我，只要時間允許，歡迎把活動訊息丟給我。
						</p>
						<ul class="intro-contacts">
							<li>
								<span class="intro-contacts__label">Email</span>
								<span class="intro-contacts__value">
									<a href="mailto:harry750110@gmail.com">harry750110@gmail.com</a>
								</span>
							</li>
							<li>
								<span class="intro-contacts__label">Line</span>
								<span class="intro-contacts__value">harryvan</span>
							</li>
							<li>
								<span class="intro-contacts__label">Facebook</span>
								<span class="intro-contacts__value">Harris Fan</span>
							</li>
						</ul>
					</div>
					<figure class="intro-portrait">
						<img src={`${import.meta.env.BASE_URL}images/harry-fan.webp`} alt="Harry Fan" />
						<figcaption>(手上拿的不是衛生紙，是烤鴨三吃)</figcaption>
					</figure>
				</div>
			</section>
			
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
									<img
										width={720}
										height={360}
										src={
											resolveHeroSrc(post.data.heroImage) ??
											coverSvgDataUri(post.data.title)
										}
										alt=""
									/>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
