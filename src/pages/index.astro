---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<meta http-equiv="refresh" content="0; url=blog/">
		<link rel="canonical" href="blog/">
	</head>
	<body>
		<main style="min-height:100vh;display:grid;place-items:center;padding:2rem;">
			<div style="text-align:center;">
				<h1 style="margin:0 0 .25rem 0;">正在前往 Blog</h1>
				<p style="margin:.5rem 0 1rem 0;color:var(--gray);">若未自動跳轉，請點擊下方連結</p>
				<p><a href="blog/" style="text-decoration:underline;">前往 /blog</a></p>
			</div>
		</main>
		<script>
			if (typeof window !== 'undefined') {
				window.location.replace('blog/');
			}
		</script>
	</body>
</html>
